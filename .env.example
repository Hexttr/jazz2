# Пароль админки (по умолчанию 513277). Сгенерировать: node scripts/hash-password.js 513277
# Обязательно в кавычках — иначе $ в bcrypt обрежется при разборе .env
ADMIN_PASSWORD_HASH="$2b$12$9V4hnzIOmQWlVyMNcajmUeC.qVJPhV97xVaVjSSX/pfWS0jmy6hZa"
# Секрет JWT (≥32 символа). Пример: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-use-long-random-string-at-least-32-chars

# Уведомления в Telegram при новой заявке: бот @BotFather, токен ниже; ID чата — в админке (Бронирование).
# TELEGRAM_BOT_TOKEN=

# SQLite: контент, заявки, Telegram ID (по умолчанию data/app.db). Можно вынести вне каталога деплоя:
# DATABASE_PATH=/var/lib/jazz2/app.db
# Загруженные в админке картинки — storage/uploads/ (URL /uploads/...).
