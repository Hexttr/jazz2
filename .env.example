# Секрет для подписи сессии (замените на случайную строку в проде)
SESSION_SECRET=your-secret-at-least-32-chars

# Хранилище контента и заявок (меню, разделы, бронирование). Нужен Redis:
# Vercel → Storage → Connect Store → Upstash Redis (или Vercel KV).
# Поддерживаются: UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
# или KV_REST_API_URL + KV_REST_API_TOKEN (Vercel KV).
# BLOB_READ_WRITE_TOKEN — только для контента, если Redis не подключён.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# BLOB_READ_WRITE_TOKEN=

# Уведомления в Telegram при новой заявке на бронирование: создайте бота через @BotFather, вставьте токен. ID получателя задаётся в админке (раздел «Бронирование»).
# TELEGRAM_BOT_TOKEN=
